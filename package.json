{
  "name": "rightminds-maps",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "knip": "knip",
    "typecheck": "tsc -b --pretty false",
    "data:prepare": "node scripts/prepare-data.mjs",
    "data:structure": "node --env-file=.env scripts/structure-data.mjs",
    "data:fetch": "node --env-file=.env scripts/fetch-data.mjs",
    "data:fetch-all": "node --env-file=.env scripts/fetch-all-data.mjs",
    "data:fetch-level3": "node --env-file=.env scripts/fetch-level3-data.mjs"
  },
  "dependencies": {
    "maplibre-gl": "^5.24.0",
    "pmtiles": "^4.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^24.9.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/xml2js": "^0.4.14",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "knip": "^6.25.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.10"
  }
}
